# App
APP_ENV=local
LOG_LEVEL=INFO

# Gemini
GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_clinic_booker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Ingestion
EMBEDDING_BATCH_SIZE=100

# App
APP_ENV=local
LOG_LEVEL=INFO
APP_PORT=8000
# CORS (TASK-032) — comma-separated origins allowed to call the API (e.g. the
# domain the chat widget is embedded on). "*" (default) is fine for local/dev.
ALLOWED_ORIGINS=*
# Chat rate-limit (TASK-033) — max messages/minute per (client IP, conversation_id).
CHAT_RATE_LIMIT_PER_MINUTE=10
# Admin API lock — set to true only on public deploys (e.g. Render) to block
# admin/write CRUD routes (doctor/booking admin actions, knowledge CRUD) with
# a 403. Leave false for local dev (default) for full access, no extra config.
IS_ADMIN_API_LOCKED=true

# Gemini (ADR-0006) — model choice is env-driven, change here without a code change.
GEMINI_API_KEY=
# gemini_llm_model/llm_temperature/llm_max_tokens below are legacy shared
# defaults, superseded by the per-agent fields further down (TASK-017).
GEMINI_LLM_MODEL=gemini-2.5-flash
# RAG's own model — used only by embed_batch(), independent of every
# per-agent chat model below.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Default output-token ceiling for common/gemini_client.py::generate() callers that don't pass
# their own max_output_tokens override (e.g. eval/deepeval_gemini.py's LLM-judge, which needs room
# for long structured JSON output — see BUG-003 in backlog/bugs/). Real chat agents built via
# google.adk.agents.Agent() are unaffected by this value.
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=120
LLM_RETRY_MAX=3

# Per-agent LLM config (TASK-017) — each agent's model/temperature/max_tokens
# is tunable independently; defaults match the legacy shared values above.
ORCHESTRATOR_LLM_MODEL=gemini-2.5-flash
ORCHESTRATOR_LLM_TEMPERATURE=0.0
ORCHESTRATOR_LLM_MAX_TOKENS=2048

BOOKING_LLM_MODEL=gemini-2.5-flash
BOOKING_LLM_TEMPERATURE=0.0
BOOKING_LLM_MAX_TOKENS=2048

SYMPTOM_LLM_MODEL=gemini-2.5-flash
SYMPTOM_LLM_TEMPERATURE=0.0
SYMPTOM_LLM_MAX_TOKENS=2048

FAQ_LLM_MODEL=gemini-2.5-flash
FAQ_LLM_TEMPERATURE=0.0
FAQ_LLM_MAX_TOKENS=2048

EMERGENCY_LLM_MODEL=gemini-2.5-flash
EMERGENCY_LLM_TEMPERATURE=0.0
EMERGENCY_LLM_MAX_TOKENS=2048

# Postgres — composed into database_url (postgresql+asyncpg://...) by common/config.py.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_clinic_booker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Managed Postgres (Neon/Supabase — used by the Render.com demo deploy, see
# docs/render-deploy.md) rejects non-SSL connections; set to true for those, leave false for
# local docker-compose Postgres.
POSTGRES_SSL=false

# Qdrant — composed into qdrant_url (http://...) by common/config.py.
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# Managed Qdrant Cloud (used by the Render.com demo deploy) is HTTPS-only and requires an
# api-key; local docker-compose Qdrant needs neither.
QDRANT_HTTPS=false
QDRANT_API_KEY=
QDRANT_COLLECTION=ai_clinic_knowledge
# Multi-server deploy — this same collection name is used verbatim for a
# local single-language dev setup. A real vn/jp/en 3-server deploy sets this
# to a *different* value per server (e.g. ai_clinic_knowledge_vn/_jp/_en) so
# the 3 servers use separate collections on the one shared Qdrant instance —
# no extra code needed, this var is already 100% env-driven.
# LANG_SUFFIX (below) does the equivalent split for the RAG Postgres tables.

# Fixed per-process language for the multi-server deploy (vn/jp/en — NOT
# "ja"). Only affects Postgres: appended to the 3 RAG content tables
# (knowledge_base/knowledge_chunks/ingestion_jobs, see dal/*_repository.py)
# so each of the 3 language-specific servers owns its own tables on the one
# shared Postgres instance. Must be one of vn/jp/en — an invalid value fails
# fast at startup (common/config.py::Settings._validate_lang_suffix) rather
# than silently defaulting.
LANG_SUFFIX=vn
# scripts/seed_eval_fixtures.py picks its fixtures/ dir from this and cross-checks it against
# LANG_SUFFIX above (must match, or the script refuses to run — see its _seed_lang()).
SEED_LANG=vn
SIMILARITY_THRESHOLD=0.7
# FAQ-only, slightly lower cutoff for higher recall on non-medical clinic content (Nhóm B task 5 — FAQ improvements, 2026-07-10).
# Symptom Agent keeps using the stricter SIMILARITY_THRESHOLD above.
FAQ_SIMILARITY_THRESHOLD=0.6
TOP_K=6

# Ingestion (ADR-0021) — chunk_max_size/overlap match ARCH-001 §5.5.
EMBEDDING_BATCH_SIZE=100
# Ingestion cron toggle — set to false only for the Render demo deploy (see
# docs/render-deploy.md), where CEO runs modules/knowledge_ingestion's cron pipeline from a
# local machine instead. Leave true (default) for local docker-compose/every other deploy —
# unchanged behavior, the scheduler still starts as before.
ENABLE_INGESTION_CRON=true
SEMANTIC_CHUNKER_THRESHOLD_TYPE=percentile
SEMANTIC_CHUNKER_THRESHOLD_AMOUNT=80.0
SEMANTIC_CHUNKER_BUFFER_SIZE=2
CHUNK_MAX_SIZE=1000
CHUNK_OVERLAP=150
CHUNK_MIN_SIZE=100
INGESTION_JOB_BATCH_SIZE=3
JOB_STUCK_MINUTES=30
JOB_MAX_RETRY=3

# Cron intervals (seconds), ADR-0021
CRON_CHUNK_INTERVAL_SECONDS=300
CRON_EMBED_INTERVAL_SECONDS=300
CRON_SWEEP_INTERVAL_SECONDS=600

# Grounded generation (ADR-0008)
NOT_FOUND_MESSAGE="I could not find relevant information in the knowledge base."

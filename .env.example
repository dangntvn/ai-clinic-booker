# App
APP_ENV=local
LOG_LEVEL=INFO
APP_PORT=8000
# CORS (TASK-032) — comma-separated origins allowed to call the API (e.g. the
# domain the chat widget is embedded on). "*" (default) is fine for local/dev.
ALLOWED_ORIGINS=*

# Gemini (ADR-0006) — model choice is env-driven, change here without a code change.
GEMINI_API_KEY=
# gemini_llm_model/llm_temperature/llm_max_tokens below are legacy shared
# defaults, superseded by the per-agent fields further down (TASK-017).
GEMINI_LLM_MODEL=gemini-2.0-flash
# RAG's own model — used only by embed_batch(), independent of every
# per-agent chat model below.
GEMINI_EMBEDDING_MODEL=text-embedding-004
# Default output-token ceiling for common/gemini_client.py::generate() callers that don't pass
# their own max_output_tokens override (e.g. eval/deepeval_gemini.py's LLM-judge, which needs room
# for long structured JSON output — see BUG-003 in backlog/bugs/). Real chat agents built via
# google.adk.agents.Agent() are unaffected by this value.
LLM_MAX_TOKENS=8192

# Per-agent LLM config (TASK-017) — each agent's model/temperature/max_tokens
# is tunable independently; defaults match the legacy shared values above.
ORCHESTRATOR_LLM_MODEL=gemini-2.0-flash
ORCHESTRATOR_LLM_TEMPERATURE=0.0
ORCHESTRATOR_LLM_MAX_TOKENS=2048

BOOKING_LLM_MODEL=gemini-2.0-flash
BOOKING_LLM_TEMPERATURE=0.0
BOOKING_LLM_MAX_TOKENS=2048

SYMPTOM_LLM_MODEL=gemini-2.0-flash
SYMPTOM_LLM_TEMPERATURE=0.0
SYMPTOM_LLM_MAX_TOKENS=2048

FAQ_LLM_MODEL=gemini-2.0-flash
FAQ_LLM_TEMPERATURE=0.0
FAQ_LLM_MAX_TOKENS=2048

EMERGENCY_LLM_MODEL=gemini-2.0-flash
EMERGENCY_LLM_TEMPERATURE=0.0
EMERGENCY_LLM_MAX_TOKENS=2048

# Postgres — composed into database_url (postgresql+asyncpg://...) by common/config.py.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_clinic_booker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Qdrant — composed into qdrant_url (http://...) by common/config.py.
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=ai_clinic_knowledge
SIMILARITY_THRESHOLD=0.7
# FAQ-only, slightly lower cutoff for higher recall on non-medical clinic content (Nhóm B task 5 — FAQ improvements, 2026-07-10).
# Symptom Agent keeps using the stricter SIMILARITY_THRESHOLD above.
FAQ_SIMILARITY_THRESHOLD=0.6
TOP_K=6

# Ingestion (ADR-0021)
EMBEDDING_BATCH_SIZE=100
